# PostgreSQL（asyncpg驱动）
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/solaice_db

# AWS S3（首尔区域）
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=solaice-pet-health-dev   # prod时改为 solaice-pet-health-prod

# CORS（逗号分隔，开发阶段可用 *）
ALLOWED_ORIGINS=http://localhost:8081,exp://
